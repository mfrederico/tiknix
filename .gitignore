# Configuration (contains credentials)
conf/config.ini
conf/mailgun.ini
conf/aibuilder.ini
conf/github.ini
conf/config.*.ini
!conf/*.example.ini

# Python cache
__pycache__/
*.pyc

# First-run setup lock (written on first successful admin login)
storage/installed.lock

# Database files
database/*.db
database/*.sqlite

# Cache
cache/
*.cache

# Logs
log/*.log

# Uploads live in public/uploads (web-served, under the docroot) and secure/uploads
# (outside the docroot, NOT web-served). BOTH are tracked & published — the only
# difference is web reachability. This ignores only the legacy/deprecated uploads/ dir.
uploads/

# Workbench project workspaces (cloned repos)
projects/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code workspace files (auto-generated for each workspace)
.claude/
.mcp.json
.playwright-mcp/

# OS
.DS_Store
Thumbs.db

# Composer
vendor/
composer.lock

# Node.js
node_modules/
package-lock.json
.mcp_token
.mcp_url
